# roomieorder environment — copy to .env (gitignored) and fill in.
# Loaded by direnv (.envrc) in dev; injected via systemd EnvironmentFile in prod.

# ─────────── Safety ───────────
# DRY_RUN stops the buy flow before the final "Place your order" click.
# Keep this true until you've watched every item reach its review page.
DRY_RUN=true

# Global ceiling, in dollars, across all orders per rolling 24h. Exceeding it
# pauses the worker and alerts. (per-item price_ceiling lives in catalog.json)
ROOMIEORDER_DAILY_CAP=200.00

# Same item_key tapped twice inside this window is ignored (double-tap guard).
ROOMIEORDER_DEBOUNCE_SECONDS=60

# ─────────── Intake service ───────────
ROOMIEORDER_HOST=127.0.0.1
ROOMIEORDER_PORT=8723
# Shared secret for POST /reorder. Leave empty for the loopback-only default.
# REQUIRED once you widen ROOMIEORDER_HOST to serve HA on the LAN — otherwise any
# device on the network can trigger spending. Callers send it as the
# `X-Roomieorder-Token` header.
ROOMIEORDER_INTAKE_TOKEN=

# ─────────── Paths ───────────
ROOMIEORDER_CATALOG=catalog.json
ROOMIEORDER_DB=data/state.sqlite
# Base browser-profile dir. Each store gets its own subdir — data/profile/costco
# and data/profile/amazon — so their sessions and anti-bot state stay isolated.
# Sign into each with `roomieorder login --provider costco|amazon`.
ROOMIEORDER_PROFILE_DIR=data/profile
ROOMIEORDER_SHOTS_DIR=data/shots

# ─────────── Stores ───────────
# Costco is tried first; Amazon is the fallback when Costco is sold out, not
# carried, or over its price ceiling.
ROOMIEORDER_COSTCO_DOMAIN=costco.com
ROOMIEORDER_AMAZON_DOMAIN=amazon.com
# Pass --ozone-platform=wayland to Chromium (set true on a Wayland session).
ROOMIEORDER_WAYLAND=false

# ─────────── Browser / anti-bot ───────────
# Akamai fingerprints the real browser build, so drive Google Chrome, not
# Playwright's bundled Chromium (which lacks proprietary codecs and brands its
# Sec-CH-UA as "Chromium"). Pin an exact binary here (the NixOS module sets this
# to the nixpkgs google-chrome); leave empty to let CHANNEL find a system Chrome.
ROOMIEORDER_CHROME_PATH=
# Playwright browser channel used when CHROME_PATH is empty. "chrome" → system
# Google Chrome. Set empty to fall back to the bundled Chromium (least stealthy).
ROOMIEORDER_CHROME_CHANNEL=chrome

# ─────────── Google Sheets ───────────
# Path to the service-account JSON key. Share the target sheet with the
# service account's email (editor). Leave SHEET_ID empty to disable logging.
GOOGLE_SERVICE_ACCOUNT_JSON=secrets/service-account.json
ROOMIEORDER_SHEET_ID=
ROOMIEORDER_SHEET_TAB=Orders

# ─────────── Notifications (OpenClaw) ───────────
# The worker shells out to the openclaw binary per message.
OPENCLAW_BIN=openclaw
OPENCLAW_TARGET=
OPENCLAW_CHANNEL=telegram
