      "Bash(.venv/bin/roomieorder failures:*)",
      "Bash(.venv/bin/roomieorder queue:*)",
      "Bash(.venv/bin/roomieorder catalog:*)",
      "Bash(.venv/bin/roomieorder dump-dom:*)",
