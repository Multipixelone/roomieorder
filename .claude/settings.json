      "Bash(roomieorder failures:*)",
      "Bash(roomieorder queue:*)",
      "Bash(roomieorder catalog:*)",
      "Bash(roomieorder dump-dom:*)",
      "Bash(roomieorder verify-selectors:*)",
      "Bash(.venv/bin/roomieorder doctor)",
