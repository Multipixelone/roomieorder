use flake

# Mirror the deployed roomieorder unit's environment so a `roomieorder` run from
# this shell reads the same catalog, Chrome, caps, host/port, profile and
# secrets the systemd user service uses. Both come from one source: nix/module.nix
# builds baseEnv, ships it to /etc/roomieorder/env (infra publishes the module's
# envFile), and the unit's EnvironmentFile carries the secrets at the agenix path.
dotenv_if_exists /etc/roomieorder/env      # non-secret baseEnv (store paths, catalog, caps…)
dotenv_if_exists /run/agenix/roomieorder   # secrets the unit's EnvironmentFile carries

# The unit sets ROOMIEORDER_DB/PROFILE_DIR (and sometimes SHOTS_DIR) *relative*
# and cd's into its StateDirectory before exec. direnv exports env but can't cd,
# so anchor any still-relative state path to the same StateDirectory (absolute) —
# this lands on the live state.sqlite/profile, the persistent Costco login.
roomie_state="${XDG_STATE_HOME:-$HOME/.local/state}/roomieorder"
for v in ROOMIEORDER_DB ROOMIEORDER_PROFILE_DIR ROOMIEORDER_SHOTS_DIR; do
  val="${!v}"
  case "$val" in
    "" | /*) : ;; # unset or already absolute — leave it
    *) export "$v=$roomie_state/$val" ;;
  esac
done

# Local overrides win last.
dotenv_if_exists .env.test
dotenv_if_exists .env
